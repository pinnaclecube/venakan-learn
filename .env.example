# ============================================================================
# Venakan Learn — environment variables
# Copy this file to `.env` (local) and set the same values in Vercel.
# NEVER commit a real `.env`. NEVER expose the service-role key to the client.
# ============================================================================

# --- Client-safe (exposed to the browser; must be prefixed with VITE_) --------
# Your Supabase project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# Supabase anon/public key. Safe to expose — it is gated by Row-Level Security.
VITE_SUPABASE_ANON_KEY=

# --- Server-only (Vercel serverless functions ONLY — never prefix with VITE_) -
# Supabase service-role key. Bypasses RLS. Used only inside /api functions.
# DO NOT expose this to the client and DO NOT prefix it with VITE_.
SUPABASE_SERVICE_ROLE_KEY=

# Same project URL, available to serverless functions (no VITE_ prefix).
SUPABASE_URL=

# Public base URL of the deployed app, used to build invite links.
# Local: http://localhost:5173   Prod: https://learn.venakaninfo.com
APP_URL=http://localhost:5173

# Anthropic API key (SERVER-ONLY — used by the /api generation functions to call
# Claude). NEVER expose this to the client and DO NOT prefix it with VITE_.
ANTHROPIC_API_KEY=

# --- Vercel Sandbox credentials (SERVER-ONLY — grading; Prompt 6) -------------
# Used by /api/submit-and-grade to run UNTRUSTED candidate code in an isolated
# Vercel Sandbox MicroVM. OPTIONAL in production on Vercel: the SDK uses the
# platform OIDC token automatically (VERCEL_OIDC_TOKEN), so you usually do NOT
# set these in prod. Provide all THREE for local/explicit auth.
#
# These are SERVER-ONLY: never prefix with VITE_, never expose to the client
# bundle, and they are NEVER passed into the candidate sandbox env (the sandbox
# is created with an empty env — no SUPABASE_*/ANTHROPIC_API_KEY/VERCEL_* reach it).
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
